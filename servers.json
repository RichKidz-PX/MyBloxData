import requests
import json
import time

# Thay đổi các thông tin này
GITHUB_TOKEN = "TOKEN_CUA_BAN"
REPO_NAME = "ten_user/MyBloxData"
PLACE_ID = "79091703265657" # Ví dụ Sea 2

def get_roblox_servers():
    url = f"https://games.roblox.com/v1/games/{PLACE_ID}/servers/Public?sortOrder=Asc&limit=100"
    response = requests.get(url)
    if response.status_code == 200:
        data = response.json()
        # Chỉ lấy ID của những server còn chỗ (ví dụ dưới 12 người) để hop cho nhanh
        server_list = [s['id'] for s in data['data'] if s['playing'] < 12]
        return server_list
    return []

def update_github(servers):
    # Logic dùng GitHub API để cập nhật file servers.json
    # (Bạn có thể dùng GitHub Actions để làm việc này tự động mỗi 5 phút)
    print(f"Tìm thấy {len(servers)} server ngon. Đang đẩy lên database...")

# Vòng lặp quét liên tục
while True:
    servers = get_roblox_servers()
    if servers:
        update_github(servers)
    time.sleep(300) # 5 phút quét 1 lần
